def advanced_search(library_name, plex, **filters):
    try:
        library = plex.library.section(library_name)
        results = library.search(**filters)
        print(f"\nAdvanced search results:")
        for media in results:
            print(f"- {media.title} ({media.year}) [{media.type}]")
    except Exception as e:
        print(f"Error in advanced search: {e}")

def list_media(library_name, media_type, plex, detailed=False):
    try:
        library = plex.library.section(library_name)
        if media_type is None:
          print(f"\nMedia in '{library_name}':")
          media_entries = library.all()
        else:
          print(f"\nMedia in '{library_name}' ({media_type}):")
          if media_type == "series" or media_type == "show":
              media_entries = library.all().get('show')
          elif media_type == "movie":
              media_entries = library.all().get('movie')

        for media in media_entries:
             if media.type == 'show':
                 print(f"Series\t{media.title} ({media.year}): {len(media.seasons())} seasons")
                 if detailed:
                     for season in media.seasons():
                         if (len(season.title)>0): print(f"Series\t{media.title} Season {season.index}: {season.title}")
                         for episode in season.episodes():
                             print(f"Series\t{media.title} S{season.index:02d}E{episode.index:02d}: {episode.title}\t'{episode.media[0].parts[0].file}'")
             elif media.type == 'movie':
                 if detailed: print(f"Movie\t{media.title} ({media.year})\t'{media.media[0].parts[0].file}'")
                 else:        print(f"Movie\t{media.title} ({media.year})")

    except Exception as e:
        print(f"Error listing media: {e}")

def refresh_media(library_name, media_identifier, plex):
    try:
        media = resolve_media_by_path_or_title(library_name, media_identifier, plex)
        media.refresh()
        print(f"Refreshed '{media.title}'.")
    except Exception as e:
        print(f"Error refreshing media: {e}")

def delete_media(library_name, media_identifier, plex):
    try:
        media = resolve_media_by_path_or_title(library_name, media_identifier, plex)
        media.delete()
        print(f"Deleted '{media.title}'.")
    except Exception as e:
        print(f"Error deleting media: {e}")

