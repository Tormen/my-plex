    # Note: --info is now in GLOBAL_CMD_PARSER, so it's in remaining_args
    if len(sys.argv)==1 or args.help == 'default' or (args.help is None and len(remaining_args) == 0 and not FORCE_CACHE_UPDATE and not args.verify_cache):
        if DBG: print( f"{DBGPFX}main_print_help(): standard help output..." )
        main_parser.print_help() #(sys.stderr)
