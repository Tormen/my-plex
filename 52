    # Normalize --watched/--unwatched/--audio to auto-inject --list when used with a library
    # This simplifies argparse by ensuring canonical form
    has_list = '--list' in sys.argv or '--list-duplicates' in sys.argv
    has_duplicates = '--duplicates' in sys.argv
    has_broken = '--broken' in sys.argv
    has_resolve = '--resolve' in sys.argv
    has_watched = '--watched' in sys.argv
    has_unwatched = '--unwatched' in sys.argv
    has_audio = any(arg.startswith('--audio') or arg in ['--en', '--english', '--de', '--german', '--fr', '--french'] for arg in sys.argv)

    if has_resolve and not (has_list and has_duplicates):
        # --resolve requires --list --duplicates, inject them if not present
        normalized_argv = [sys.argv[0]]  # Keep script name
        for arg in sys.argv[1:]:
            if arg == '--resolve':
                # Inject --list --duplicates before --resolve
                if not has_list:
                    normalized_argv.append('--list')
                if not has_duplicates:
                    normalized_argv.append('--duplicates')
                normalized_argv.append(arg)
                # Mark that we've added them
                has_list = True
                has_duplicates = True
            else:
                normalized_argv.append(arg)

        sys.argv = normalized_argv
        if DBG or DEEPDBG:
            print(f" ~~~ Normalized sys.argv (--resolve) = {sys.argv}", file=sys.stderr)
    elif (has_duplicates or has_broken) and not has_list:
        # Find position of --duplicates or --broken and inject --list before it
        normalized_argv = [sys.argv[0]]  # Keep script name
        for arg in sys.argv[1:]:
            if arg == '--duplicates' or arg == '--broken':
                # Inject --list before --duplicates or --broken
                normalized_argv.append('--list')
                normalized_argv.append(arg)
                # Mark that we've added --list
                has_list = True
            else:
                normalized_argv.append(arg)

        sys.argv = normalized_argv
        if DBG or DEEPDBG:
            print(f" ~~~ Normalized sys.argv = {sys.argv}", file=sys.stderr)
    elif (has_watched or has_unwatched or has_audio) and not has_list:
        # Filter flags require --list to be meaningful with a library
        # Inject --list when using --watched, --unwatched, or audio filters
        normalized_argv = [sys.argv[0]]  # Keep script name
        injected = False
        for arg in sys.argv[1:]:
            if not injected and (arg == '--watched' or arg == '--unwatched' or arg.startswith('--audio') or arg in ['--en', '--english', '--de', '--german', '--fr', '--french']):
                # Inject --list before the first filter flag
                normalized_argv.append('--list')
                normalized_argv.append(arg)
                injected = True
                has_list = True
            else:
                normalized_argv.append(arg)

        sys.argv = normalized_argv
        if DBG or DEEPDBG:
            print(f" ~~~ Normalized sys.argv (filters) = {sys.argv}", file=sys.stderr)

    # Early argument parsing for --config-file option
