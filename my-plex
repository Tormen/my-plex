#!/bin/sh

# 004 == highest used errCode

NL="
"
RC=0;

NOW=$( date +"%Y-%m-%d_%H%M.%S");
LOG="/tmp/my-plex.log.$NOW.$$"
LOG=""

err() { local errCode="$1"; [ -z "$2" ] && local msg="" || local msg=": $2"; [ -z "$3" ] && local exitCode=1 || local exitCode="$3";
  local outp="ERROR $errCode [$exitCode]$msg"
  echo "${NL}$outp" >>"$LOG"
  exit $exitCode;
}

my_echo() { [ -n "$LOG" ] && echo "$1" >> "$LOG" || echo "$1"; }

#######################################################################

ENVDIR=~/".python.venv/my-plex"

# Detect verbose and debug mode from args
VRB=0
DBG=0
for _arg in "$@"; do
  case "$_arg" in -V|--verbose|-VV|--very-verbose) VRB=1;; esac
  case "$_arg" in -D|--debug|-DD|--deep-debug) DBG=1;; esac
done

[ -n "$LOG" ] && echo "Output of $0 goes to '$LOG'.${NL}Output of my-plex.py goes to stdout AND to '$LOG'."

[ $DBG -eq 1 ] && my_echo "ENVDIR='$ENVDIR'"

[ -d "$ENVDIR" -a -x "$ENVDIR"/bin/python3 -a -n "$( ls -d "$ENVDIR"/lib/*/site-packages/plexapi 2>/dev/null )" ] || {

  my_echo "${NL} >>> Creating python virtualenv '$ENVDIR'...${NL}"
  mkdir -p "$ENVDIR" || err 001;
  virtualenv "$ENVDIR" || err 002;
  source "$ENVDIR"/bin/activate || err 003;
  pip install plexapi readchar || err 004;
  my_echo "${NL} >>> DONE creating python virtualenv '$ENVDIR'."
  my_echo "================================================================${NL}"
}

# Set up zsh completions for the current user (run unconditionally)
COMPLETION_DIR="${HOME}/.zsh/completions"
COMPLETION_FILE="${COMPLETION_DIR}/_my-plex"

# Create completions directory if it doesn't exist
if [ ! -d "$COMPLETION_DIR" ]; then
  mkdir -p "$COMPLETION_DIR" 2>/dev/null
fi

# Create/update completion script
if [ -d "$COMPLETION_DIR" ]; then
  cat > "$COMPLETION_FILE" << 'COMPLETION_EOF'
#compdef my-plex

_my-plex() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    # Debug: log to file (uncomment to debug completion issues)
    #echo "DEBUG: words=$words" >> /tmp/completion-debug.log

    # Check which flags are already in the command line
    local has_duplicates=0
    local has_list=0
    local has_update_cache=0
    local has_broken=0
    local has_resolve=0
    local has_problems=0
    for word in $words; do
        if [[ "$word" == "--list-duplicates" ]]; then
            has_duplicates=1
            has_list=1
        elif [[ "$word" == "--duplicates" ]]; then
            has_duplicates=1
            has_list=1  # --duplicates auto-enables --list, so --type should be available
        elif [[ "$word" == "--broken" ]]; then
            has_broken=1
            has_list=1  # --broken auto-enables --list, so --type should be available
        elif [[ "$word" == "--resolve" ]]; then
            has_resolve=1
            has_duplicates=1  # --resolve auto-enables --duplicates
            has_list=1  # --resolve auto-enables --list, so --type should be available
        elif [[ "$word" == "--list" ]]; then
            has_list=1
        elif [[ "$word" == "--update-cache" ]] || [[ "$word" == "--rebuild-cache" ]] || [[ "$word" == "-U" ]]; then
            has_update_cache=1
        fi
    done

    # Debug: log flags detected (uncomment to debug completion issues)
    #echo "DEBUG: has_duplicates=$has_duplicates has_list=$has_list has_update_cache=$has_update_cache" >> /tmp/completion-debug.log

    # Build arguments list conditionally
    local -a args_spec
    args_spec=(
        '--info[Show system information (cache, server, libraries)]'
        '--verify-cache[Verify cache consistency with Plex server]'
        '(-U --update-cache --rebuild-cache)'{-U,--update-cache,--rebuild-cache}'[Update/rebuild cache from server]'
        '(-O --offline)'{-O,--offline}'[Work with cached information only (offline mode)]'
        '--plex-url[Plex server URL]:url:'
        '--plex-token[Plex authentication token]:token:'
        '--plex-xml-url[Plex XML URL from View XML]:xml-url:'
        '--list[List all media items]'
        '--list-libraries[List all Plex libraries]'
        '--list-duplicates[List only duplicate media items]'
        '--broken[Show only potentially truncated/broken files]'
        '--excess-versions[List entries with too many file versions]:limit:'
        '--problems[Run all problem detection checks]'
        '--scan[Trigger Plex library scan + metadata refresh + cache update]'
        '--rename[Rename episode files according to EPISODE_NAME_PATTERN config]'
        '--resolve[Interactive duplicate resolution (auto-enables --list --duplicates)]'
        '(--collections --collection)'{--collections,--collection}'[List collections in a library]'
        '--list-labels[List all labels and item counts]'
        '--list-label[List media with specific label]:label:'
        '--add-label[Add label to media]:label and id:'
        '--remove-label[Remove label from media]:label and id:'
        '(--no-audio-language --no-language)'{--no-audio-language,--no-language}'[List media with missing audio language info]'
        '--en[List media with English audio]'
        '--de[List media with German audio]'
        '--fr[List media with French audio]'
        '--watched[List watched media items]'
        '--unwatched[List unwatched media items]'
        '(--remove --rm)'{--remove,--rm}'[Trash media files (optionally specify version indices/ranges)]:indices:'
        '(--delete --del)'{--delete,--del}'[Delete Plex entry (metadata only)]'
        '--test[Run regression tests]'
        '(- -V -VV --verbose --very-verbose)'{-V,--verbose}'[Verbose output]'
        '(- -V -VV --verbose --very-verbose)'{-VV,--very-verbose}'[Very verbose output]'
        '(- -D -DD --debug --deep-debug)'{-D,--debug}'[Debug mode]'
        '(- -D -DD --debug --deep-debug)'{-DD,--deep-debug}'[Deep debug mode]'
        '(- -h --help)'{-h,--help}'[Show help message]'
    )

    # Only add --force/--from-scratch/--force-plexdata/--force-metadata if --update-cache is present
    if [[ $has_update_cache -eq 1 ]]; then
        args_spec+=('--force[Force complete cache rebuild from scratch]')
    fi

    # Only add --duplicates if --list is present (but not if --list-duplicates or --resolve is already there)
    if [[ $has_list -eq 1 ]] && [[ $has_duplicates -eq 0 ]]; then
        args_spec+=('--duplicates[Filter --list to show only duplicates]')
    fi

    # Only add --type if --list, --list-duplicates, or --resolve is present
    if [[ $has_list -eq 1 ]]; then
        args_spec+=('--type[Filter by media type]:type:(movie show)')
    fi

    _arguments -s : '*::arg:_default' $args_spec
}

_my-plex "$@"

COMPLETION_EOF

    # Ensure fpath includes the completions directory
    # Must be added BEFORE oh-my-zsh is sourced (if using oh-my-zsh)
    ZSHRC="${HOME}/.zshrc"
    if [ -f "$ZSHRC" ] || [ -L "$ZSHRC" ]; then
      # Check if fpath line already exists (check for both ~ and full path versions)
      if ! grep -q "fpath=.*\.zsh/completions" "$ZSHRC" 2>/dev/null; then
        # Resolve symlink if needed
        if [ -L "$ZSHRC" ]; then
          ZSHRC_REAL="$(readlink "$ZSHRC")"
          # Handle relative symlinks
          case "$ZSHRC_REAL" in
            /*) ;; # Absolute path, use as-is
            *) ZSHRC_REAL="${HOME}/${ZSHRC_REAL}" ;; # Relative, make absolute
          esac
        else
          ZSHRC_REAL="$ZSHRC"
        fi

        # Find the line that sources oh-my-zsh
        if grep -q "source.*oh-my-zsh.sh" "$ZSHRC_REAL" 2>/dev/null; then
          # Insert fpath BEFORE oh-my-zsh is sourced
          sed -i.bak '/source.*oh-my-zsh.sh/i\
# my-plex zsh completions\
fpath=('"${COMPLETION_DIR}"' $fpath)\
' "$ZSHRC_REAL"
        else
          # No oh-my-zsh, append at end
          echo "" >> "$ZSHRC_REAL"
          echo "# my-plex zsh completions" >> "$ZSHRC_REAL"
          echo "fpath=(${COMPLETION_DIR} \$fpath)" >> "$ZSHRC_REAL"
          echo "autoload -Uz compinit && compinit" >> "$ZSHRC_REAL"
        fi
      fi
    fi
fi

if [ -n "$1" -a -s "$1" ]; then
   #echo "/usr/bin/env -v \"$ENVDIR\"/bin/python3 ""$@""|tee -a \"$LOG\"" >>"$LOG"
   #/usr/bin/env -v "$ENVDIR"/bin/python3 "$@"|tee -a "$LOG"
   [ $DBG -eq 1 ] && my_echo "\"$ENVDIR\"/bin/python3 ""$@""|tee -a \"$LOG\""
   if [ -n "$LOG" ]; then "$ENVDIR"/bin/python3 "$@"|tee -a "$LOG"; RC=$?;
                     else "$ENVDIR"/bin/python3 "$@"; RC=$?; fi
else
   WHAT="/LINKS/src/,py/prj/my-plex/my-plex.py"
   #echo "/usr/bin/env -v \"$ENVDIR\"/bin/python3 \"$WHAT\" ""$@""|tee -a \"$LOG\"" >>"$LOG"
   #/usr/bin/env -v "$ENVDIR"/bin/python3 "$WHAT" "$@"|tee -a "$LOG"
   [ $DBG -eq 1 ] && my_echo "\"$ENVDIR\"/bin/python3 \"$WHAT\" ""$@""|tee -a \"$LOG\""
   if [ -n "$LOG" ]; then "$ENVDIR"/bin/python3 "$WHAT" "$@"|tee -a "$LOG"; RC=$?;
                     else "$ENVDIR"/bin/python3 "$WHAT" "$@"; RC=$?; fi;
fi

exit $RC;
