# my-plex configuration file
#
# IMPORTANT: All values below are commented out and show the built-in defaults.
# Uncomment and modify only the values you want to change.
#
# Copy this file to ~/.my-plex.conf (or /etc/my-plex.conf, /usr/local/etc/my-plex.conf)
#
# Configuration priority (highest to lowest):
#   1. Command-line arguments (--plex-url, --debug, etc.)
#   2. This config file (uncommented values)
#   3. Built-in defaults (shown below as comments)
#
# Only PLEX_URL/PLEX_TOKEN or PLEX_XML_URL must be configured.
# All other variables are optional and use sensible defaults.

###############################################################################
# Plex Server Configuration (REQUIRED - uncomment and configure)
###############################################################################

# Option 1: Set PLEX_URL and PLEX_TOKEN separately
# PLEX_URL = '< PLEASE CONFIGURE /or/ USE PLEX_XML_URL >'
# PLEX_TOKEN = '< PLEASE CONFIGURE /or/ USE PLEX_XML_URL >'

# Option 2: Use PLEX_XML_URL (from "View XML" in Plex)
# PLEX_XML_URL = '< PLEASE CONFIGURE /or/ USE PLEX_URL + PLEX_TOKEN >'

# Example with real values (uncomment and customize):
# PLEX_URL = 'https://192-168-1-100.abc123.plex.direct:32400'
# PLEX_TOKEN = 'your-token-here'
# Or:
# PLEX_XML_URL = 'https://192-168-1-100.abc123.plex.direct:32400/library/metadata/12345?X-Plex-Token=your-token-here'

# How to get the token:
# https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/

###############################################################################
# Path Configuration
###############################################################################

# Alternative root paths for symlinks or different mount points
# ALTERNATIVE_ROOTPATHS = [('/j2/watch.v/', '/Volumes/2/watch.v/')]

###############################################################################
# Output Configuration
###############################################################################

# FORMAT = 'tsv_labeled'
# LIST_MEDIA_DEFAULT_TSV_FORMAT = '{LIBRARY}\t{TYPE_STR}\t{ID}\t{TITLE}\t{ORIGINALTITLE}\t{DURATION}\t{YEAR}\t{S0XE0X}\t{MEDIA_NR}\t{VERSION}\t{PART_NR}\t{PART_ID}\t{FILE}\t{UPDATEDAT}\t{ADDEDAT}\t{UPDATEDAT}\t{LASTVIEWEDAT}\t{VIEWCOUNT}\t{USERRATING}\t{CRITICSRATING}\t{AUDIENCERATING}\t{AUDIO_LANGUAGES}\t{SUBTITLE_LANGUAGES}\t{COUNTRIES}\t{COLLECTIONS}\t{LABELS}\t{GENRES}\t{DIRECTORS}\t{WRITERS}\t{ACTORS}\t{SUMMARY}'
# DUPLICATE_FILE = '/tmp/duplicates'
# DBGPFX = ' ~~~ '
# PRINTPFX = ' >>> '
# VRBPFX = '  >> '

###############################################################################
# Cache Configuration
###############################################################################

# CACHE_FILE = '.plex_media_cache.pkl'
# LOCK_FILE = '.plex_media_cache.lock'
# CACHE_CHECKPOINT_INTERVAL = 100

###############################################################################
# Performance Configuration
###############################################################################

# MAX_PARALLEL_WORKERS = 4
# RATE_LIMIT_DELAY_RANGE = (0.1, 0.7)
# LIBRARY_START_DELAY = 1.0

###############################################################################
# Retry Configuration
###############################################################################

# PLEX_RETRY_DELAYS = [5, 30, 60, 120, 240, 480]
# PLEX_TIMEOUT = 42

###############################################################################
# Debug/Verbose Flags
###############################################################################

# DBG = False
# VRB = False
# VERYVRB = False
# DEEPDBG = False
# OFFLINE = False

###############################################################################
# Cache Flags
###############################################################################

# FORCE_CACHE_UPDATE = False
# FORCE_REBUILD = False
# READ_ONLY_MODE = False
