def get_alternative_paths(path, including_path=False):
    global ALTERNATIVE_ROOTPATHS
    if including_path: res = [path]
    else:              res = []
    for (rootpath1,rootpath2) in ALTERNATIVE_ROOTPATHS:
        if path.startswith(rootpath1):
            new_path = path.replace(rootpath1, rootpath2, 1) # max 1 replacement
            res.append( new_path )
        elif path.startswith(rootpath2):
            new_path = path.replace(rootpath2, rootpath1, 1) # max 1 replacement
            res.append( new_path )
    return res

def get_plexpaths():
    """ collect_all_paths_linked_to_plex_libraries_including_alternative_paths() and return PLEXPATHS dictionary """
    global PLEX_SERVER
    if DBG: print(f"{DBGPFX}get_plexpaths()")

    res = {}
    # Iterate over each library section
    for section in PLEX_SERVER.library.sections():
        if DBG: print(f"{DBGPFX}get_plexpaths: LOOP 1 (libraries) > library '{section.title}'")
        # List all paths for the current library
        for path in section.locations:
            if DBG: print(f"{DBGPFX}get_plexpaths: LOOP 2 (section.locations) >> path '{path}'")
            for alternative_path in get_alternative_paths(path, including_path=True):
                if DBG: print(f"{DBGPFX}get_plexpaths: LOOP 3 (alternative_paths) >>> alternative_path '{alternative_path}'")
                if alternative_path in res:
                    if DBG: print(f"{DBGPFX}get_plexpaths: EXISTING dict entry: res[{alternative_path}] = {res[alternative_path]} ++ ['{section.title}']")
                    # making sure entry is unique - not sure if this CAN happen... but better save
                    if section.title not in res[alternative_path]: res[alternative_path].append(section.title) 
                else:
                    if DBG: print(f"{DBGPFX}get_plexpaths: NEW dict entry: res[{alternative_path}] = ['{section.title}']")
                    res[alternative_path] = [section.title]
    return res

def init_plex_connection(args):
    global PLEX_SERVER, PLEXPATHS
    if PLEX_SERVER is None: PLEX_SERVER = connect_to_plex(args.plex_url, args.plex_token)
    if PLEXPATHS is None: PLEXPATHS = get_plexpaths()

def resolve_media_by_path_or_title(media_identifier, library_name=None):
    """Resolve media entry by title or file path and optional library_name.
       With or without library_name:
          1.) we try to get media_identifier_realpath (=realpath(media_identifier))
          2.) we'll check if either media_identifier OR media_identifier_realpath startwith one of the paths in the PLEXPATHS dict.
       For the case that media_dentifier is a PATH:
          1.) all matching libraries are then searched for media_identifier to confirm that PLEX knows about this file
       For the case that media_identifier is a MEDIA-TITLE:
          2.) all matching libraries are used to lookup media_identifier (as title)
          ELSE
          3.) all matching libraries are used to SEARCH for media_identifier
    """

    global PLEX_SERVER, PLEXPATHS

    if DBG: print(f"{DBGPFX}resolve_media_by_path_or_title( media_identifier='{media_identifier}', library='{library_name}')")
    if media_identifier is None: err(1008, f"This should never be. Please contact maintainer.")

    if library_name is None:
        potential_libraries = []
    else:
        potential_libraries = [library_name]
    if DBG: print(f"{DBGPFX}resolve_media_by_path_or_title() potential_libraries = {potential_libraries} -- based on root-path of libraries!")

    # Gather all potential libraries based on PLEXPATHS dict - this already contains all altnerative paths versions (to compare our path againast)!
    for (path,library_names) in PLEXPATHS.items():
        if DBG: print(f"{DBGPFX}resolve_media_by_path_or_title() LOOP over PLEXPATHS: path='{path}'")
        if media_identifier.startswith(path):
            for x in library_names: potential_libraries.append(x) if x not in potential_libraries else next # push only NEW library_names
        if DBG: print(f"{DBGPFX}resolve_media_by_path_or_title() LOOP over PLEXPATHS: after media_identifier check: potential_libraries={potential_libraries}")

    try:
        normalized_filepath = os.path.normpath(media_identifier)
        # If file exists -> search for it
        for library_name in potential_libraries:
            if DBG: print(f"{DBGPFX}resolve_media_by_path_or_title() LOOP over potential_libraries: > library_name='{library_name}'")
            library = PLEX_SERVER.library.section(library_name)
            # Iterate through all items in the library
            for item in library.all():
                # Search within movies
                if item.type == 'movie':
                    for media in item.media:
                        for part in media.parts:
                            if os.path.normpath(part.file) == normalized_filepath:
                                print(f"File '{filepath}' found as part of movie '{item.title}' ({item.year})")
                                return item  # Return the found item

                # Search within TV shows (seasons and episodes)
                elif item.type == 'show':
                    for season in item.seasons():
                        for episode in season.episodes():
                            for media in episode.media:
                                for part in media.parts:
                                    if os.path.normpath(part.file) == normalized_filepath:
                                        print(f"File '{filepath}' found as part of episode '{episode.title}' in show '{item.title}'")
                                        return episode  # Return the found episode
    except:
        pass

    print("XXX")            
    sys.exit(0)

    for entry in library.all():
        if DBG: print(f"{DBGPFX}resolve_media_by_path_or_title() LOOP over entries: >> entry '{entry}'")
        match entry.TYPE:
            case 'movie': all_items = [entry]
            case 'show': all_items = entry.episodes()
            case _: err(1009, f"Invalid item.TYPE {entry.TYPE}: {entry}. Please report to maintainer.")
        for item in all_items:
            if DBG: print(f"{DBGPFX}resolve_media_by_path_or_title() LOOP over items: >> item '{item}'")
            for part in item.iterParts(): # Iterates over the parts of this media item.
                if DBG: print(f"{DBGPFX}resolve_media_by_path_or_title() LOOP over parts: >> part '{part}'")
                # to compare part.file with our media_identifier, first collect ALTERNATIVE versions of part.file:
                for path in get_alternative_paths( part.file ):
                    if DBG: print(f"{DBGPFX}resolve_media_by_path_or_title() LOOP over all versions of part.file: >>> path '{path}'")
                    if path == media_identifier:
                        if DBG: print(f"{DBGPFX}resolve_media_by_path_or_title() LOOP over : >> matched part.file '{part}' with path!")
                        return item
    if DBG: print(f"{DBGPFX}resolve_media_by_path_or_title() LOOP over potential_libraries: Unable to match part.file of all parts of all items of all potential libraries")
    try:
        # First, try to find by title
        if DBG: print(f"{DBGPFX}resolve_media_by_path_or_title() LOOP over potential_libraries: Using media_identifier as title to lookup media...")
        media = library.get(media_identifier)
        if DBG: print(f"{DBGPFX}resolve_media_by_path_or_title() LOOP over potential_libraries: FOUND media by title!")
        return media
    except:
        if DBG: print(f"{DBGPFX}resolve_media_by_path_or_title() LOOP over potential_libraries: Did NOT find media by title!")
        # If not found by title, search for it
        try:
            if DBG: print(f"{DBGPFX}resolve_media_by_path_or_title() LOOP over potential_libraries: Searching media via media_identifier...")
            media = PLEX_SERVER.library.search(media_identifier)[0]
            if DBG: print(f"{DBGPFX}resolve_media_by_path_or_title() LOOP over potential_libraries: FOUND media by search in library!")
            return media
        except:
            if DBG: print(f"{DBGPFX}resolve_media_by_path_or_title() LOOP over potential_libraries: NOT found media by search in library!")
            next
            #raise Exception(f"Media not found for title or file path: {media_identifier}")

    # in case potential_libraries would be empty list /or/ in case NON of the attempts in LOOP over potential_libraries was able to find 'media':
    return None

