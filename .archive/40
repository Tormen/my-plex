import argparse
from plexapi.server import PlexServer
from plexapi.playlist import Playlist
from plexapi.collection import Collection
from datetime import datetime

# Plex Server credentials
PLEX_URL = 'http://<PLEX_SERVER_IP>:32400'
PLEX_TOKEN = '<YOUR_PLEX_TOKEN>'

# Connect to Plex server
def connect_plex():
    try:
        plex = PlexServer(PLEX_URL, PLEX_TOKEN)
        print(f"Connected to Plex server: {plex.friendlyName}")
        return plex
    except Exception as e:
        print(f"Failed to connect to Plex: {e}")
        return None

# Playlist management --------------------------------------------------

def create_playlist(playlist_name, media_titles, plex):
    try:
        media_items = [plex.library.search(title)[0] for title in media_titles]
        Playlist.create(server=plex, title=playlist_name, items=media_items)
        print(f"Playlist '{playlist_name}' created successfully.")
    except Exception as e:
        print(f"Error creating playlist: {e}")

def update_playlist(playlist_name, media_titles, action, plex):
    try:
        playlist = plex.playlist(playlist_name)
        media_items = [plex.library.search(title)[0] for title in media_titles]
        
        if action == 'add':
            playlist.addItems(media_items)
            print(f"Media added to playlist '{playlist_name}'.")
        elif action == 'remove':
            playlist.removeItems(media_items)
            print(f"Media removed from playlist '{playlist_name}'.")
    except Exception as e:
        print(f"Error updating playlist: {e}")

def delete_playlist(playlist_name, plex):
    try:
        playlist = plex.playlist(playlist_name)
        playlist.delete()
        print(f"Playlist '{playlist_name}' deleted successfully.")
    except Exception as e:
        print(f"Error deleting playlist: {e}")

# Collection management ------------------------------------------------

def add_to_collection(collection_name, media_titles, plex):
    try:
        collection = plex.library.collection(collection_name)
    except:
        collection = Collection.create(server=plex, title=collection_name, section=plex.library.section('Movies'))

    media_items = [plex.library.search(title)[0] for title in media_titles]
    for media in media_items:
        media.addCollection(collection_name)
        print(f"Media '{media.title}' added to collection '{collection_name}'.")

def remove_from_collection(collection_name, media_titles, plex):
    try:
        collection = plex.library.collection(collection_name)
        media_items = [plex.library.search(title)[0] for title in media_titles]
        
        for media in media_items:
            media.removeCollection(collection_name)
            print(f"Media '{media.title}' removed from collection '{collection_name}'.")
    except Exception as e:
        print(f"Error removing media from collection: {e}")

def list_collections(library_name, plex):
    try:
        library = plex.library.section(library_name)
        print(f"\nCollections in library '{library_name}':")
        for collection in library.collections():
            print(f"- {collection.title}")
    except Exception as e:
        print(f"Error listing collections: {e}")

# Metadata management ---------------------------------------------------

def get_watched_status(title, plex):
    try:
        media = plex.library.search(title)[0]
        print(f"Watched status of '{media.title}': {'Watched' if media.isWatched else 'Unwatched'}")
        print(f"Last viewed at: {media.lastViewedAt if media.isWatched else 'N/A'}")
        print(f"View count: {media.viewCount}")
    except Exception as e:
        print(f"Error fetching watched status: {e}")

def set_watched(title, plex):
    try:
        media = plex.library.search(title)[0]
        media.markWatched()
        print(f"Media '{media.title}' marked as watched.")
    except Exception as e:
        print(f"Error setting watched status: {e}")

def set_unwatched(title, plex):
    try:
        media = plex.library.search(title)[0]
        media.markUnwatched()
        print(f"Media '{media.title}' marked as unwatched.")
    except Exception as e:
        print(f"Error setting unwatched status: {e}")

def set_watched_date(title, watched_date, plex):
    try:
        media = plex.library.search(title)[0]
        media.markWatched()
        media.lastViewedAt = watched_date
        media.save()
        print(f"Watched date set to {watched_date} for '{media.title}'.")
    except Exception as e:
        print(f"Error setting watched date: {e}")

def set_view_offset(title, offset, plex):
    try:
        media = plex.library.search(title)[0]
        media.updateProgress(viewOffset=offset, viewCount=media.viewCount)
        print(f"View offset set to {offset} milliseconds for '{media.title}'.")
    except Exception as e:
        print(f"Error setting view offset: {e}")

def get_view_offset(title, plex):
    try:
        media = plex.library.search(title)[0]
        print(f"Current view offset of '{media.title}': {media.viewOffset} milliseconds.")
    except Exception as e:
        print(f"Error fetching view offset: {e}")

def set_user_rating(title, rating, plex):
    try:
        media = plex.library.search(title)[0]
        media.userRating = rating
        media.save()
        print(f"User rating set to {rating} for '{media.title}'.")
    except Exception as e:
        print(f"Error setting user rating: {e}")

def clear_user_rating(title, plex):
    try:
        media = plex.library.search(title)[0]
        media.userRating = None
        media.save()
        print(f"User rating cleared for '{media.title}'.")
    except Exception as e:
        print(f"Error clearing user rating: {e}")

def advanced_search(library_name, plex, **filters):
    try:
        library = plex.library.section(library_name)
        results = library.search(**filters)
        print(f"\nAdvanced search results:")
        for media in results:
            print(f"- {media.title} ({media.year}) [{media.type}]")
    except Exception as e:
        print(f"Error in advanced search: {e}")

def get_media_info(title, plex):
    try:
        media = plex.library.search(title)[0]
        print(f"\nDetails of '{media.title}':")
        print(f"- Type: {media.type}")
        print(f"- Year: {media.year}")
        print(f"- Rating: {media.rating}")
        print(f"- Summary: {media.summary}")
        print(f"- Duration: {media.duration}")
        print(f"- Director: {', '.join([d.tag for d in media.directors])}")
        print(f"- Writers: {', '.join([w.tag for w in media.writers])}")
        print(f"- Genres: {', '.join([g.tag for g in media.genres])}")
        print(f"- Collection: {', '.join([c.tag for c in media.collections])}")
    except Exception as e:
        print(f"Error fetching media info: {e}")

def main():
    parser = argparse.ArgumentParser(description="Plex API Utility Script")

    # Connection setup
    parser.add_argument('--connect', action='store_true', help="Connect to Plex server.")

    # Playlist commands
    parser.add_argument('--create-playlist', nargs='+', help="Create a playlist. Example: --create-playlist <playlist_name> <media1> <media2>...")
    parser.add_argument('--update-playlist', nargs=3, help="Update playlist. Example: --update-playlist <playlist_name> add <media1> [or 'remove']")
    parser.add_argument('--delete-playlist', help="Delete a playlist. Example: --delete-playlist <playlist_name>")

    # Collection commands
    parser.add_argument('--add-to-collection', nargs='+', help="Add media to collection. Example: --add-to-collection <collection_name> <media1> <media2>...")
    parser.add_argument('--remove-from-collection', nargs='+', help="Remove media from collection. Example: --remove-from-collection <collection_name> <media1> <media2>...")
    parser.add_argument('--list-collections', help="List collections in a library. Example: --list-collections <library_name>")

    # Metadata commands
    parser.add_argument('--get-watched-status', help="Get watched status of media. Example: --get-watched-status <media_title>")
    parser.add_argument('--set-watched', help="Set media as watched. Example: --set-watched <media_title>")
    parser.add_argument('--set-unwatched', help="Set media as unwatched. Example: --set-unwatched <media_title>")
    parser.add_argument('--set-watched-date', nargs=2, help="Set the watched date for media. Example: --set-watched-date <media_title> <YYYY-MM-DD HH:MM:SS>")
    parser.add_argument('--set-view-offset', nargs=2, help="Set view offset for media. Example: --set-view-offset <media_title> <offset_in_milliseconds>")
    parser.add_argument('--get-view-offset', help="Get view offset for media. Example: --get-view-offset <media_title>")
    parser.add_argument('--set-user-rating', nargs=2, help="Set user rating for media. Example: --set-user-rating <media_title> <rating>")
    parser.add_argument('--clear-user-rating', help="Clear user rating for media. Example: --clear-user-rating <media_title>")
    
    # Advanced search
    parser.add_argument('--advanced-search', nargs='*', help="Perform an advanced search. Example: --advanced-search <library_name> <filter1=value1> <filter2=value2>...")
    
    # Media info
    parser.add_argument('--get-media-info', help="Get detailed information about media. Example: --get-media-info <media_title>")

    # Parse arguments
    args = parser.parse_args()
    plex = connect_plex()

    # Execute commands based on parsed arguments
    if args.connect:
        plex = connect_plex()

    if args.create_playlist:
        create_playlist(args.create_playlist[0], args.create_playlist[1:], plex)

    if args.update_playlist:
        update_playlist(args.update_playlist[0], args.update_playlist[2:], args.update_playlist[1], plex)

    if args.delete_playlist:
        delete_playlist(args.delete_playlist, plex)

    if args.add_to_collection:
        add_to_collection(args.add_to_collection[0], args.add_to_collection[1:], plex)

    if args.remove_from_collection:
        remove_from_collection(args.remove_from_collection[0], args.remove_from_collection[1:], plex)

    if args.list_collections:
        list_collections(args.list_collections, plex)

    if args.get_watched_status:
        get_watched_status(args.get_watched_status, plex)

    if args.set_watched:
        set_watched(args.set_watched, plex)

    if args.set_unwatched:
        set_unwatched(args.set_unwatched, plex)

    if args.set_watched_date:
        set_watched_date(args.set_watched_date[0], args.set_watched_date[1], plex)

    if args.set_view_offset:
        set_view_offset(args.set_view_offset[0], int(args.set_view_offset[1]), plex)

    if args.get_view_offset:
        get_view_offset(args.get_view_offset, plex)

    if args.set_user_rating:
        set_user_rating(args.set_user_rating[0], float(args.set_user_rating[1]), plex)

    if args.clear_user_rating:
        clear_user_rating(args.clear_user_rating, plex)

    if args.advanced_search:
        library_name = args.advanced_search[0]
        filters = {item.split('=')[0]: item.split('=')[1] for item in args.advanced_search[1:]}
        advanced_search(library_name, plex, **filters)

    if args.get_media_info:
        get_media_info(args.get_media_info, plex)

if __name__ == '__main__':
    main()
